# --- API Keys ---
# Get your key at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_key_here

# GitHub Personal Access Token (classic or fine-grained)
GITHUB_TOKEN=your_github_token_here

# Groq API Key: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio Key: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- LLM Configuration ---
# 0.0 for deterministic outputs, higher (e.g., 0.7) for creativity
LLM_TEMPERATURE=0.0

# --- LangSmith Tracing ---
# Enable tracing to debug your agent's thought process
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=my-agent-project

# --- Agent Settings ---
# Options usually include: sequential, parallel
AGENT_MODE=parallel

# Limit the number of loops the agent can perform to prevent infinite recursions
MAX_REVISIONS=6